# Окружение
NODE_ENV=development

# База данных PostgreSQL
DB_HOST=localhost
DB_PORT=4202
DB_USERNAME=beton_user
DB_PASSWORD=your_secure_password_here
DB_NAME=beton_crm
DB_SSL=false
DB_POOL_SIZE=10

# Redis
REDIS_HOST=localhost
REDIS_PORT=4203
REDIS_PASSWORD=

# Приложение
PORT=4201
APP_PORT=4201
CLIENT_PORT=4200

# JWT
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# Bitrix24
BITRIX24_WEBHOOK_URL=https://crm.betonexpress.pro/rest/3/74sbx907svrq1v10/

# CORS
CORS_ORIGIN=http://localhost:4200

# PgAdmin (опционально)
PGADMIN_EMAIL=admin@beton.local
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050

# Логирование
LOG_LEVEL=info
LOG_FORMAT=json

# Email (для уведомлений)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@beton-crm.local

# Безопасность
ADMIN_PASSWORD=change-this-admin-password
BCRYPT_ROUNDS=10
SESSION_SECRET=your_session_secret_here
COOKIE_SECURE=false

# Social Auth (OAuth2)
# Google: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Yandex: https://oauth.yandex.ru/
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=

# VK: https://dev.vk.com/
VK_CLIENT_ID=
VK_CLIENT_SECRET=

# URL приложения (для OAuth callback)
APP_URL=http://localhost:4201
FRONTEND_URL=http://localhost:4200

# Файловое хранилище
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# Кеширование
CACHE_TTL=3600
CACHE_PREFIX=beton

# Миграции
TYPEORM_MIGRATIONS_RUN=true
TYPEORM_LOGGING=false
TYPEORM_SYNCHRONIZE=false