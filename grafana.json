				"defaults": {
					"color": {
						"mode": "thresholds"
					},
					"mappings": [],
					"thresholds": {
						"mode": "absolute",
						"steps": [
							{
								"color": "green",
								"value": 0
							},
							{
								"color": "yellow",
								"value": 10
							},
							{
								"color": "red",
								"value": 50
							}
						]
					}
				},
				"overrides": []
			},
			"gridPos": {
				"h": 4,
				"w": 4,
				"x": 0,
				"y": 1
