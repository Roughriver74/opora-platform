				"colorMode": "background",
				"graphMode": "area",
				"justifyMode": "auto",
				"orientation": "auto",
				"percentChangeColorMode": "standard",
				"reduceOptions": {
					"calcs": ["sum"],
					"fields": "",
					"values": false
				},
				"showPercentChange": false,
				"textMode": "value_and_name",
				"wideLayout": true
			},
			"pluginVersion": "12.3.0",
			"targets": [
				{
					"expr": "sum(count_over_time({host=\"$host_label\"} |~ \"(?i)(error|exception|fatal|critical)\" !~ \"(?i)(Socket connection|context canceled|Errno -2)\" [1h]))",
