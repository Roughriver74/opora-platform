{
	"name": "server",
	"version": "1.0.0",
	"main": "index.js",
	"scripts": {
		"start": "node dist/index.js",
		"dev": "nodemon --exec ts-node --transpile-only src/index.ts",
		"build": "tsc",
		"create-test-user": "ts-node --transpile-only src/scripts/createTestUser.ts",
		"typeorm": "typeorm-ts-node-commonjs",
		"migration:generate": "typeorm-ts-node-commonjs migration:generate -d src/database/config/database.config.ts",
		"migration:run": "typeorm-ts-node-commonjs migration:run -d src/database/config/database.config.ts",
		"migration:run:prod": "node ./node_modules/typeorm/cli.js migration:run -d dist/database/config/database.config.js",
		"migration:revert": "typeorm-ts-node-commonjs migration:revert -d src/database/config/database.config.ts",
		"db:check": "ts-node --transpile-only src/database/migrations/scripts/check-tables.ts",
		"db:clean": "ts-node --transpile-only src/database/migrations/scripts/clean-db.ts",
		"db:verify": "ts-node --transpile-only src/database/migrations/scripts/verify-import.ts",
		"test:elasticsearch": "ts-node --transpile-only src/scripts/testElasticsearch.ts"
	},
	"keywords": [],
	"author": "",
	"license": "ISC",
	"description": "",
	"dependencies": {
		"@elastic/elasticsearch": "^8.11.0",
		"@types/bcrypt": "^5.0.2",
		"@types/bcryptjs": "^2.4.6",
		"axios": "^1.9.0",
		"bcrypt": "^6.0.0",
		"bcryptjs": "^3.0.2",
		"body-parser": "^2.2.0",
		"class-transformer": "^0.5.1",
		"class-validator": "^0.14.2",
		"cors": "^2.8.5",
		"node-cron": "^3.0.3",
		"dotenv": "^16.5.0",
		"express": "^5.1.0",
		"jsonwebtoken": "^9.0.2",
		"pg": "^8.16.3",
		"redis": "^4.7.1",
		"reflect-metadata": "^0.2.2",
		"typeorm": "^0.3.25"
	},
	"devDependencies": {
		"@types/cors": "^2.8.18",
		"@types/express": "^5.0.2",
		"@types/jsonwebtoken": "^9.0.10",
		"@types/node": "^22.15.30",
		"@types/pg": "^8.15.5",
		"@types/redis": "^4.0.11",
		"nodemon": "^3.1.10",
		"ts-node": "^10.9.2",
		"typescript": "5.4.5"
	}
}
