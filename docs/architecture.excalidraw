    {
      "id": "db-features-content",
      "type": "text",
      "x": 2490,
      "y": 1660,
      "width": 900,
      "height": 140,
      "fontSize": 16,
      "fontFamily": 1,
      "text": "⚡ 20+ стратегические индексы (status+createdAt, userId+status, priority, tags, etc.)\n📊 Денормализованные поля (formName, userName) - избежать JOIN'ов\n🧮 Precomputed aggregates (dayOfWeek, processingTime) - для analytics\n📝 JSONB fields (formData, options, settings) - гибкость\n🗑️ Cascade deletes (Form → FormField)\n🔍 Полнотекстовый поиск (tsvector + GIN index на Company.searchVector)\n💾 TypeORM migrations для версионирования schema",
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 132,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "groupIds": [
        "database"
      ],
      "frameId": "frame-database",
      "locked": false,
      "version": 2,
      "versionNonce": 1992372398,
      "index": "b0B",
      "isDeleted": false,
      "strokeStyle": "solid",
      "seed": 1,
      "roundness": null,
      "boundElements": [],
      "updated": 1768898530685,
      "link": null,
      "containerId": null,
      "originalText": "⚡ 20+ strategic indices (status+createdAt, userId+status, priority, tags, etc.)\n📊 Denormalized fields (formName, userName) - избежать JOIN'ов\n🧮 Precomputed aggregates (dayOfWeek, processingTime) - для analytics\n📝 JSONB fields (formData, options, settings) - гибкость\n🗑️ Cascade deletes (Form → FormField)\n🔍 Full-text search (tsvector + GIN index на Company.searchVector)\n💾 TypeORM migrations для версионирования schema",
      "autoResize": true,
      "lineHeight": 1.25
    },
