      "version": 2,
      "versionNonce": 717070898,
      "index": "b04",
      "isDeleted": false,
      "strokeStyle": "solid",
      "seed": 1,
      "roundness": null,
      "boundElements": [],
      "updated": 1768898530685,
      "link": null,
      "originalText": "✏️ FormField:\nPK: id (UUID)\nFK: formId → Form\n• sectionId, name, label\n• type (text, email, phone, date,\n  dropdown, autocomplete, radio,\n  checkbox, textarea, file, header)\n• required, placeholder\n• bitrixFieldId, bitrixFieldType\n• options (JSONB) [{value, label}]\n• dynamicSource (JSONB)\n  {enabled, source, filter}\n• linkedFields (JSONB)\n  {enabled, mappings[]}\n• order, isActive\n\nIndices: (formId, order),\n        (formId, sectionId, order)",
      "autoResize": true,
      "lineHeight": 1.0714285714285714
    },
