    {
      "id": "legend-colors",
      "type": "text",
      "x": 70,
      "y": 120,
      "width": 540,
      "height": 230,
      "fontSize": 16,
      "fontFamily": 1,
      "text": "Цвета:\n🔵 Blue (#E3F2FD) - Фронтенд (React)\n🟠 Orange (#FFF3E0) - Бэкенд (Express)\n🟣 Purple (#F3E5F5) - База данных (PostgreSQL)\n🟢 Green (#E8F5E9) - Внешние сервисы (Bitrix24)\n🟡 Yellow (#FFF9C4) - Кэш (в памяти)\n🌸 Pink (#FCE4EC) - Elasticsearch\n⚪ Gray (#CFD8DC) - Docker\n\nСтрелки:\n→ Сплошная - Синхронный вызов\n⤍ Пунктирная - Асинхронный вызов\n⋯> Точечная - Поток ошибок",
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 222,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "groupIds": [
        "legend-group"
      ],
      "frameId": null,
      "locked": false,
      "version": 2,
      "versionNonce": 1818547186,
      "index": "a4",
      "isDeleted": false,
      "strokeStyle": "solid",
      "seed": 1,
      "roundness": null,
      "boundElements": [],
      "updated": 1768898530685,
      "link": null,
      "containerId": null,
      "originalText": "Colors:\n🔵 Blue (#E3F2FD) - Frontend (React)\n🟠 Orange (#FFF3E0) - Backend (Express)\n🟣 Purple (#F3E5F5) - Database (PostgreSQL)\n🟢 Green (#E8F5E9) - External (Bitrix24)\n🟡 Yellow (#FFF9C4) - Cache (Memory)\n🌸 Pink (#FCE4EC) - Elasticsearch\n⚪ Gray (#CFD8DC) - Docker\n\nArrows:\n→ Solid - Synchronous call\n⤍ Dashed - Asynchronous call\n⋯> Dotted - Error flow",
      "autoResize": true,
      "lineHeight": 1.1057692307692308
    },
