    {
      "id": "formfield-entity-text",
      "type": "text",
      "x": 2490,
      "y": 955,
      "width": 460,
      "height": 270,
      "fontSize": 14,
      "fontFamily": 1,
      "text": "✏️ Поле Формы:\nPK: id (UUID)\nFK: formId → Form\n• sectionId, name, label\n• type (text, email, phone, date,\n  dropdown, autocomplete, radio,\n  checkbox, textarea, file, header)\n• обязательное, placeholder\n• bitrixFieldId, bitrixFieldType\n• options (JSONB) [{value, label}]\n• dynamicSource (JSONB)\n  {enabled, source, filter}\n• linkedFields (JSONB)\n  {enabled, mappings[]}\n• order, isActive\n\nИндексы: (formId, order),\n        (formId, sectionId, order)",
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 262,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "groupIds": [
        "database"
      ],
      "frameId": "frame-database",
      "containerId": "formfield-entity-box",
