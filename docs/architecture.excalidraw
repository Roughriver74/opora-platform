    {
      "id": "webhook-text",
      "type": "text",
      "x": 4070,
      "y": 995,
      "width": 480,
      "height": 170,
      "fontSize": 14,
      "fontFamily": 1,
      "text": "🪝 Обработчик Webhook:\n\nPOST /api/sync/from-bitrix\n(публичный endpoint)\n\nВход: Bitrix24 webhook данные\n       {dealId, newStatus, fields}\n\nОбработка:\n1. Найти заявку по bitrixDealId\n2. Update status from Bitrix24\n3. Map Bitrix24 status → local status\n4. CREATE ЗаявкаHistory entry\n5. Возврат 200 OK",
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 162,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "groupIds": [
        "integrations"
      ],
      "frameId": "frame-integrations",
      "locked": false,
      "version": 2,
      "versionNonce": 2118479474,
      "index": "b0I",
      "isDeleted": false,
      "strokeStyle": "solid",
      "seed": 1,
      "roundness": null,
      "boundElements": [],
      "updated": 1768898530685,
      "link": null,
      "containerId": null,
      "originalText": "🪝 Webhook Handler:\n\nPOST /api/sync/from-bitrix\n(публичный endpoint)\n\nInput: Bitrix24 webhook payload\n       {dealId, newStatus, fields}\n\nProcessing:\n1. Find submission by bitrixDealId\n2. Update status from Bitrix24\n3. Map Bitrix24 status → local status\n4. CREATE SubmissionHistory entry\n5. Return 200 OK",
      "autoResize": true,
      "lineHeight": 0.8673469387755102
    },
