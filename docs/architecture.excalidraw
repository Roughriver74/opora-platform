      "updated": 1768898530685,
      "link": null,
      "originalText": "BetoneForm Component:\n\n• FormSection (collapsible)\n• FormField Types:\n  text, email, phone, date\n  dropdown, autocomplete\n  radio, checkbox, textarea\n• Linked fields\n• Dynamic options\n• Yup validation",
      "autoResize": true,
      "lineHeight": 1.0625
