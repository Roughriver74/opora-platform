    },
    {
      "id": "cache-content",
      "type": "text",
      "x": 3540,
      "y": 1280,
      "width": 1010,
      "height": 120,
      "fontSize": 16,
      "fontFamily": 1,
      "text": "In-process memory storage (Map<string, {data, expires}>)\n\nПаттерн ключа: bitrix24:dynamic-options:{source}:{filter_hash}\nSources: products, companies, contacts\n\nTTL Strategy:\n• Dynamic options (products, companies): 30 min\n• Categories: 2 hours\n\nИнвалидация: Manual clear или истечение TTL",
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 112,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "groupIds": [
        "integrations"
      ],
      "frameId": "frame-integrations",
      "locked": false,
      "version": 2,
      "versionNonce": 1699152878,
      "index": "b0L",
      "isDeleted": false,
      "strokeStyle": "solid",
      "seed": 1,
      "roundness": null,
      "boundElements": [],
      "updated": 1768898530685,
      "link": null,
      "containerId": null,
      "originalText": "In-process memory storage (Map<string, {data, expires}>)\n\nKey pattern: bitrix24:dynamic-options:{source}:{filter_hash}\nSources: products, companies, contacts\n\nTTL Strategy:\n• Dynamic options (products, companies): 30 min\n• Categories: 2 hours\n\nInvalidation: Manual clear или TTL expiration",
      "autoResize": true,
      "lineHeight": 0.75
    },
